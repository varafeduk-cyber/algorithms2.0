#include <stdio.h>
#include <stdlib.h>
#include <string.h>

struct Node{
    int value;
    struct Node *left;
    struct Node *right;
    int height;
};

struct Node* createNode(int value){
    struct Node* newNode = (struct Node*)malloc(sizeof(struct Node));
    newNode->value = value;
    newNode->left = NULL;
    newNode->right = NULL;
    newNode->height = 1;
    return newNode;
}

struct Node* insertBST(struct Node* node, int value){
    if(node == NULL){
        return createNode(value);
    }
    if(value < node->value){
        node->left = insertBST(node->left,value);
    }else if(value > node->value){
        node->right = insertBST(node->right, value);
    }
    return node;
}

struct Node* buildBalancedAVL(int *arr, int start, int end){
    if(start > end){
        return NULL;
    }
    int mid = (start + end) / 2;
    struct Node* node = createNode(arr[mid]);
    node->left = buildBalancedAVL(arr, start, mid -1);
    node->right = buildBalancedAVL(arr, mid + 1, end);
    return node;

}

void printInOrder(struct Node* node){
    if(node == NULL){
        return;
    }
    printInOrder(node->left);
    printf("%d ", node->value);
    printInOrder(node->right);
}

void printPreOrder(struct Node* node){
    if(node == NULL) return;
    printf("%d ", node->value);
    printPreOrder(node->left);
    printPreOrder(node->right);
}

void printPostOrder(struct Node* node){
     if(node == NULL) return;
    printPostOrder(node->left);
    printPostOrder(node->right);
    printf("%d ", node->value);

}

//Bubble sort
void sortArray(int *arr,int n){
    for(int i = 0; i < n - 1; i++){
        for(int j = 0; j < n  - i - 1; j++){
            if(arr[j] > arr[j + 1]){
                int temp = arr[j];
                arr[j] = arr[j + 1];
                arr[j + 1] = temp;
            }
        }
    }
}

void findMin(struct Node* node){
    if(node == NULL){
        printf("Tree is empty\n");
        return;
    }
    struct Node* current = node;
    while(current->left != NULL){
        current = current->left;
    }
    printf("Min value: %d\n", current->value);
}

void findMax(struct Node* node){
    if(node == NULL){
        printf("Tree is empty\n");
        return;
    }
    struct Node* current = node;
    while(current->right != NULL){
        current = current->right;
    }
    printf("Max value: %d\n", current->value);
}

struct Node* findTheChosenOne(struct Node* node){
    struct Node* current = node;
    while(current && current->left != NULL){
        current = current->left;
    }
    return current; 
}

struct Node* deleteNode(struct Node* root, int value){
    if(root = NULL) return root;

    if(value < root->value)
        root->left = deleteNode(root->left, value);
    else if(value > root->value)
        root->right = deleteNode(root->right, value);
    else{
//1 или детей совсем нет
        if(root->left == NULL){
            struct Node* temp = root->right;
            free(root);
            return temp;
        } else if(root->right == NULL){
            struct Node* temp = root->left;
            free(root);
            return temp;
        }
// Находим преемника (самый маленький в правом дереве)
        struct Node* temp = findTheChosenOne(root->right);
 // Копируем значение преемника в текущий узел
        root->value = temp->value;
// Удаляем преемника из правого поддерева
        root->right = deleteNode(root->right, temp->value);
    }
    return root;
}

void freeTree(struct Node* node){
    if(node == NULL) return;
    freeTree(node->left);
    freeTree(node->right);
    free(node);
}

void exportToFile(struct Node* node, FILE* f){
    if(node == NULL) return;
    fprintf(f, "%d ", node->value);
    exportToFile(node->left, f);
    exportToFile(node->right, f);
}

void fillArray(struct Node* node, int* arr, int* index){
    if(node == NULL) return;
    fillArray(node->left, arr, index);
    arr[*index] = node->value;
    (*index)++;
    fillArray(node->right, arr, index);
}

struct Node* rotateRight(struct Node* root, struct Node* pivot){
    struct Node* temp = pivot->left;
    pivot->left = temp->right;
    temp->right = pivot;
    return temp; 
}

struct Node* rotateLeft(struct Node* root, struct Node* pivot){
    struct Node* temp = pivot->right;
    pivot->right = temp->left;
    temp->left = pivot;
    return temp;
}
//Day-Stout-Warren 
struct Node* balanceDSW(struct Node* root){
    if(root = NULL) return NULL;
    struct Node dummy;//vremennyj koren
    dummy.right = root;
    struct Node* prev = &dummy;
    struct Node* curr = dummy.right;
//prevraszczenie w lozu
    int count = 0;
    while(curr != NULL){
        if(curr->left != NULL){
            prev->right = rotateRight(curr,curr->left);
            curr = prev->right;
        }else {
            count++;
            prev = curr;
            curr = curr->right;
        }
    }
    //szatie cozdajem balanced derevo
    int m = 1;
    while(m <= count) m = m * 2 + 1;
    m /=2;
    curr = dummy.right;
    prev = &dummy;
    for(int i = 0; i < count - m; i++){
        prev->right = rotateLeft(curr, curr->right);
        prev = prev->right;
        curr = prev->right;
    }
    while (m > 1)
    {
        m /= 2;
        curr = dummy.right;
        prev = &dummy;
        for(int i = 0; i < m; i++){
            prev->right = rotateLeft(curr, curr->right);
            prev = prev->right;
            curr = prev->right;
        }
    }
    return dummy.right;
}

void exportTikZ(struct Node* node, FILE* f){
    if(node == NULL) return;
    fprintf(f, "node {%d}\n", node->value);
    if(node->left || node->right){
        fprintf(f, "child { ");
        if(node->left) exportTikZ(node->left, f);
        else fprintf(f, "node [missing] {}");
        fprintf(f, " }\n");
        fprintf(f, "child { ");
        if(node->right) exportTikZ(node->right, f);
        else fprintf(f, "node [missing] {}");
        fprintf(f, " }\n");
    }

}








